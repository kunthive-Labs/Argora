__pycache__/
*.pyc
.venv/
venv/
.DS_Store

# DB credentials for the direct-push path — local only, never commit.
.env
.env.local

# Scraped data + generated SQL = local only (PII; never push by mistake).
# The .gitkeep files keep the folders tracked; the contents stay out.
data/raw/*
data/leads/*
data/sql/*
data/extracts/*
data/outreach/*
!data/raw/.gitkeep
!data/leads/.gitkeep
!data/sql/.gitkeep
!data/extracts/.gitkeep
!data/outreach/.gitkeep
